#include <WiFi.h>
#include <WebServer.h>

WebServer server(80);

int _moisture, sensor_analog;
const int sensor_pin = A0;

const char* ssid = "Jan Pol Uzi";
const char* password = "12345678";

const char html_page[] PROGMEM = R"rawSrting(
<!DOCTYPE html>
<html>
<style>
    body {font-family: sans-serif;}
    h1 {text-align: center; font-size: 30px;}
    p {text-align: center; color: #4CAF50; font-size: 40px;}
</style>
 
<body>
  <h1>ESP32 Irrigation</h1><br>
  <h2></h2>
  <p>Moisture Level :<span id="MoistureVal">0</span>%</p><br>

  <script>
    setInterval(function() { 
      var xhttp = new XMLHttpRequest();
      xhttp.onreadystatechange = function() {
        if (this.readyState == 4 && this.status == 200) {
         document.getElementById("MoistureVal").innerHTML = this.responseText
        }
      };
      xhttp.open("GET", "readMoisture", true);
      xhttp.send();
    },50);
  </script>
</body>
</html>
)rawSrting";

void MainPage() {
  server.send(200, "text/html", html_page);
}

void SoilMoisture() {
  String MoistuValue = String(_moisture);
  server.send(200, "text/plain", MoistuValue);
}

void setup() {
  Serial.begin(115200);
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);

  while (WiFi.waitForConnectResult() != WL_CONNECTED) {
    Serial.print(".");
    delay(100);
  }

  Serial.println();
  Serial.print("Connected to ");
  Serial.print(ssid);
  Serial.print(" with IP address: ");

  // Print the ESP32's IP address
  IPAddress ip = WiFi.localIP();
  Serial.print(ip[0]);
  Serial.print(".");
  Serial.print(ip[1]);
  Serial.print(".");
  Serial.print(ip[2]);
  Serial.print(".");
  Serial.println(ip[3]);

  server.on("/", MainPage);
  server.on("/readMoisture", SoilMoisture);
  server.begin();
  delay(1000);
}

void loop() {
  sensor_analog = analogRead(sensor_pin);
  _moisture = (100 - ((sensor_analog / 4095.00) * 100));

  server.handleClient();

  Serial.print("Moisture = ")
  Serial.print(_moisture);
  Serial.println("%");

  delay(1000); 
}